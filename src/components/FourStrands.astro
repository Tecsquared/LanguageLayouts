---
import { strands } from '../data/templates';
---

<section class="four-strands" id="framework">
  <div class="container">
    <h2
      class="section-title reveal"
      id="strands-title"
      role="button"
      tabindex="0"
      aria-label="Reset — show all four strands"
    >'The Four Strands'</h2>
    <p class="section-subtitle reveal">The research-backed framework behind every Language Layout.</p>

    <div class="strands-content reveal">
      <div class="strands-illustration">
        <svg viewBox="0 0 220 440" class="rope-svg" aria-hidden="true">
          {strands.map((strand) => (
            <path class="rope-strand-hit" data-hit={strand.id} data-strand-click={strand.id} d=""></path>
          ))}
          {strands.map((strand) => (
            <path class="rope-strand" data-strand={strand.id} d=""></path>
          ))}
        </svg>
      </div>

      <div class="strands-controls">
        {strands.map((strand) => (
          <div class="strand-group" data-group={strand.id}>
            <button
              class="strand-btn"
              data-strand-click={strand.id}
              aria-selected="false"
              style={`--strand-color: ${strand.color};`}
            >
              <span class="strand-dot"></span>
              <span class="strand-name">{strand.name}</span>
            </button>
            <p class="strand-desc"><span>{strand.description}</span></p>
          </div>
        ))}
      </div>
    </div>

    <p class="strands-hint reveal">
      <svg class="hint-arrow" viewBox="0 0 50 26" fill="none" aria-hidden="true">
        <path d="M46 22 C34 20, 20 16, 10 5" stroke="var(--terra)" stroke-width="1.8" stroke-linecap="round" fill="none" />
        <path d="M7 12 L9 4 L17 6" stroke="var(--terra)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none" />
      </svg>
      <span class="hand-note">pull a strand or a label — go on, give it a tug</span>
    </p>
  </div>
</section>

<style>
  .four-strands {
    padding-top: 60px;
  }

  .section-title {
    cursor: pointer;
    user-select: none;
    transition: opacity 0.25s var(--ease-expo);
  }
  .section-title:hover { opacity: 0.72; }

  .strands-content {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 72px;
    align-items: center;
    max-width: 820px;
    margin: 0 auto;
  }

  .strands-illustration {
    width: 220px;
    height: 440px;
    position: relative;
  }
  .rope-svg {
    width: 100%;
    height: 100%;
    display: block;
    overflow: visible;
  }

  .rope-strand-hit {
    cursor: pointer;
    fill: none;
    stroke: transparent;
    stroke-width: 28;
    stroke-linecap: round;
  }
  .rope-strand {
    fill: none;
    stroke-linecap: round;
    transition:
      stroke 0.6s var(--ease-expo),
      stroke-width 0.6s var(--ease-expo),
      opacity 0.6s var(--ease-expo);
    pointer-events: none;
  }

  .strands-controls {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .strand-group {
    display: flex;
    flex-direction: column;
  }

  .strand-btn {
    display: flex;
    align-items: center;
    gap: 14px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px 0;
    text-align: left;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.25rem;
    letter-spacing: -0.01em;
    color: var(--ink);
    transition: opacity 0.2s, transform 0.3s var(--ease-spring);
  }
  .strand-btn:hover {
    opacity: 0.8;
    transform: translateX(4px);
  }

  .strand-dot {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: 2px solid var(--ink-soft);
    background: transparent;
    flex-shrink: 0;
    transition:
      background-color 0.4s var(--ease-expo),
      border-color 0.4s var(--ease-expo),
      transform 0.4s var(--ease-spring);
  }
  .strand-btn.active .strand-dot {
    background: var(--strand-color, var(--ink));
    border-color: var(--strand-color, var(--ink));
    transform: scale(1.18);
  }

  .strand-desc {
    color: var(--ink-soft);
    font-size: 1rem;
    line-height: 1.65;
    padding-left: 32px;
    max-width: 46ch;

    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    margin: 0;
    transition:
      grid-template-rows 0.5s var(--ease-expo),
      opacity 0.4s var(--ease-expo),
      margin-top 0.5s var(--ease-expo);
    margin-top: 0;
  }
  .strand-desc > span {
    overflow: hidden;
    min-height: 0;
  }
  .strand-group.active .strand-desc {
    grid-template-rows: 1fr;
    opacity: 1;
    margin-top: 6px;
  }

  .strands-hint {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 8px;
    margin: 48px 0 0;
  }

  .hint-arrow {
    width: 38px;
    height: 20px;
    margin-top: 4px;
  }

  .strands-hint .hand-note {
    font-size: 1.25rem;
    color: var(--muted);
    transform: rotate(-1.5deg);
  }

  @media (max-width: 760px) {
    .strands-content {
      grid-template-columns: 1fr;
      gap: 40px;
      max-width: 420px;
    }
    .strands-illustration {
      width: 180px;
      height: 320px;
      margin: 0 auto;
    }
    .strand-btn { font-size: 1.1rem; }
    .strand-desc { font-size: 0.9rem; padding-left: 28px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .rope-strand { transition: stroke 0.2s linear; }
  }
</style>

<script>
  (() => {
    'use strict';

    const STRANDS = [
      { id: 'input',    base: 50  },
      { id: 'output',   base: 97  },
      { id: 'language', base: 123 },
      { id: 'fluency',  base: 170 },
    ];

    const VIEW_W = 220;
    const VIEW_H = 440;

    const FREQ = 1.15;
    const HELIX_FREQ = 3.4;
    const HELIX_AMP = 48;
    const HELIX_SPEED_R = 0.0011;
    const CENTER_X = VIEW_W / 2;

    const PHASE_OFFSETS = [0, Math.PI * 0.5, Math.PI, Math.PI * 1.5];

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    type StrandState = {
      id: string;
      phase: number;
      colored: number;
      targetColored: number;
    };

    const state: StrandState[] = STRANDS.map((s, i) => ({
      id: s.id,
      phase: PHASE_OFFSETS[i],
      colored: 0,
      targetColored: 0,
    }));

    let activeId: string | null = null;

    const svgStrands: Record<string, SVGPathElement> = {};
    const svgHits: Record<string, SVGPathElement> = {};
    document.querySelectorAll<SVGPathElement>('.rope-strand').forEach((el) => {
      svgStrands[el.dataset.strand!] = el;
    });
    document.querySelectorAll<SVGPathElement>('.rope-strand-hit').forEach((el) => {
      svgHits[el.dataset.hit!] = el;
    });
    const svgEl = document.querySelector<SVGElement>('.rope-svg')!;

    function buildPath(cx: number, amp: number, phase: number, wrap = 0, samples = 44) {
      const pts: [number, number][] = [];
      const centerX = cx + (CENTER_X - cx) * wrap;
      const freq = FREQ + (HELIX_FREQ - FREQ) * wrap;
      for (let i = 0; i <= samples; i++) {
        const y = (i / samples) * VIEW_H;
        const u = i / samples;
        const envRest = Math.sin(u * Math.PI);
        const envHelix = 0.22 + 0.78 * Math.sin(u * Math.PI);
        const env = envRest + (envHelix - envRest) * wrap;
        const a = amp * env;
        const x = centerX + Math.sin(u * Math.PI * 2 * freq + phase) * a;
        pts.push([x, y]);
      }
      let d = `M ${pts[0][0].toFixed(2)} ${pts[0][1].toFixed(2)}`;
      for (let i = 0; i < pts.length - 1; i++) {
        const p0 = pts[i - 1] || pts[i];
        const p1 = pts[i];
        const p2 = pts[i + 1];
        const p3 = pts[i + 2] || p2;
        const c1x = p1[0] + (p2[0] - p0[0]) / 6;
        const c1y = p1[1] + (p2[1] - p0[1]) / 6;
        const c2x = p2[0] - (p3[0] - p1[0]) / 6;
        const c2y = p2[1] - (p3[1] - p1[1]) / 6;
        d += ` C ${c1x.toFixed(2)} ${c1y.toFixed(2)}, ${c2x.toFixed(2)} ${c2y.toFixed(2)}, ${p2[0].toFixed(2)} ${p2[1].toFixed(2)}`;
      }
      return d;
    }

    /* Resting grey is warm to sit on Vellum; accents are the brand strand colours */
    const GREY: [number, number, number] = [211, 203, 188];
    const ACCENT_RGB: Record<string, [number, number, number]> = {
      input:    [90, 127, 110],   /* MFI green  #5A7F6E */
      output:   [122, 107, 160],  /* MFO purple #7A6BA0 */
      language: [196, 154, 60],   /* LFL gold   #C49A3C */
      fluency:  [107, 141, 181],  /* FD blue    #6B8DB5 */
    };

    function lerp(a: number, b: number, t: number) { return a + (b - a) * t; }
    function lerpColor(c1: [number, number, number], c2: [number, number, number], t: number) {
      return `rgb(${Math.round(lerp(c1[0], c2[0], t))}, ${Math.round(lerp(c1[1], c2[1], t))}, ${Math.round(lerp(c1[2], c2[2], t))})`;
    }

    function setActive(id: string) {
      activeId = id === activeId ? null : id;

      state.forEach((s) => {
        if (activeId === null) s.targetColored = 0;
        else if (s.id === activeId) s.targetColored = 1;
        else s.targetColored = 0;
      });

      if (activeId && svgStrands[activeId]) {
        svgEl.appendChild(svgStrands[activeId]);
      }

      document.querySelectorAll<HTMLElement>('.strand-group').forEach((g) => {
        g.classList.toggle('active', g.dataset.group === activeId);
      });
      document.querySelectorAll<HTMLButtonElement>('.strand-btn').forEach((b) => {
        const isActive = b.dataset.strandClick === activeId;
        b.classList.toggle('active', isActive);
        b.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });
    }

    document.querySelectorAll<HTMLElement>('[data-strand-click]').forEach((el) => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        setActive(el.dataset.strandClick!);
      });
    });

    function resetAll() {
      if (activeId === null) return;
      activeId = null;
      state.forEach((s) => { s.targetColored = 0; });
      document.querySelectorAll<HTMLElement>('.strand-group').forEach((g) => g.classList.remove('active'));
      document.querySelectorAll<HTMLButtonElement>('.strand-btn').forEach((b) => {
        b.classList.remove('active');
        b.setAttribute('aria-selected', 'false');
      });
    }
    const titleEl = document.getElementById('strands-title');
    if (titleEl) {
      titleEl.addEventListener('click', resetAll);
      titleEl.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); resetAll(); }
      });
    }

    let lastT = performance.now();
    const WRAP = 1;

    function tick(now: number) {
      const dt = Math.min(now - lastT, 50);
      lastT = now;

      const ease = Math.min(1, dt / 220);

      state.forEach((s, i) => {
        s.colored += (s.targetColored - s.colored) * ease;

        if (!prefersReduced) {
          s.phase += HELIX_SPEED_R * dt;
        }

        const base = STRANDS[i].base;
        const d = buildPath(base, HELIX_AMP, s.phase, WRAP);
        svgStrands[s.id].setAttribute('d', d);
        svgHits[s.id].setAttribute('d', d);

        const accent = ACCENT_RGB[s.id];
        let tintMix: number;
        if (activeId === null) tintMix = 1;
        else if (activeId === s.id) tintMix = 1;
        else tintMix = s.colored;
        const color = lerpColor(GREY, accent, tintMix);

        const midPhase = Math.PI * HELIX_FREQ + s.phase;
        const depth = Math.cos(midPhase);
        const depthOpacity = 1 - 0.35 * Math.max(0, -depth);

        svgStrands[s.id].setAttribute('stroke', color);
        svgStrands[s.id].setAttribute('stroke-width', '12');
        svgStrands[s.id].setAttribute('stroke-opacity', depthOpacity.toFixed(3));
      });

      requestAnimationFrame(tick);
    }

    requestAnimationFrame(tick);
  })();
</script>
