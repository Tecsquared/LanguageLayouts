---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<div class:list={['squiggly-divider', 'reveal', className]} aria-hidden="true">
  <svg viewBox="0 0 1000 60" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <!-- One thread, four strands: each segment draws itself in turn -->
    <path
      class="thread-seg seg-1"
      pathLength="1"
      d="M0 32 C40 20, 70 44, 110 34 C150 24, 180 40, 250 30"
      stroke="var(--mfi)"
      stroke-width="3"
      stroke-linecap="round"
      fill="none"
    />
    <path
      class="thread-seg seg-2"
      pathLength="1"
      d="M250 30 C300 18, 330 44, 380 34 C430 24, 460 42, 500 30"
      stroke="var(--mfo)"
      stroke-width="3"
      stroke-linecap="round"
      fill="none"
    />
    <path
      class="thread-seg seg-3"
      pathLength="1"
      d="M500 30 C550 16, 590 46, 640 32 C690 20, 720 40, 750 30"
      stroke="var(--lfl)"
      stroke-width="3"
      stroke-linecap="round"
      fill="none"
    />
    <path
      class="thread-seg seg-4"
      pathLength="1"
      d="M750 30 C800 18, 840 44, 890 32 C940 22, 970 36, 1000 30"
      stroke="var(--fd)"
      stroke-width="3"
      stroke-linecap="round"
      fill="none"
    />
  </svg>
</div>

<style>
  .squiggly-divider {
    width: 100%;
    max-width: 700px;
    margin: 0 auto;
    padding: 40px 24px;

    /* Opt out of the standard reveal motion — the thread draws instead */
    opacity: 1 !important;
    transform: none !important;
    transition: none !important;
  }

  .squiggly-divider svg {
    width: 100%;
    height: auto;
    overflow: visible;
  }

  .thread-seg {
    stroke-dasharray: 1 1;
    stroke-dashoffset: 1;
    transition: stroke-dashoffset 0.6s var(--ease-out);
  }

  .squiggly-divider.visible .seg-1 { stroke-dashoffset: 0; transition-delay: 0s; }
  .squiggly-divider.visible .seg-2 { stroke-dashoffset: 0; transition-delay: 0.4s; }
  .squiggly-divider.visible .seg-3 { stroke-dashoffset: 0; transition-delay: 0.8s; }
  .squiggly-divider.visible .seg-4 { stroke-dashoffset: 0; transition-delay: 1.2s; }

  @media (prefers-reduced-motion: reduce) {
    .thread-seg {
      stroke-dashoffset: 0;
      transition: none;
    }
  }
</style>

<script>
  // Living threads: each divider ripples gently while it's on screen.
  // The pathLength="1" normalisation means the CSS draw-in keeps working
  // even though the path shape changes every frame.
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const dividerEls = document.querySelectorAll<HTMLElement>('.squiggly-divider');

  if (!reduced && dividerEls.length) {
    type Divider = {
      paths: SVGPathElement[];
      phase: number;
      animating: boolean;
    };

    const dividers: Divider[] = [];
    const byElement = new Map<Element, Divider>();

    dividerEls.forEach((el, idx) => {
      const d: Divider = {
        paths: Array.from(el.querySelectorAll<SVGPathElement>('.thread-seg')),
        phase: idx * 1.7,
        animating: false,
      };
      dividers.push(d);
      byElement.set(el, d);
    });

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const d = byElement.get(entry.target);
          if (d) d.animating = entry.isIntersecting;
        });
      },
      { rootMargin: '80px 0px' }
    );
    dividerEls.forEach((el) => io.observe(el));

    function waveY(u: number, phase: number) {
      return (
        30 +
        Math.sin(u * Math.PI * 2 * 2.3 + phase) * 5.5 +
        Math.sin(u * Math.PI * 2 * 5.1 + phase * 1.7) * 3
      );
    }

    function segPath(seg: number, phase: number) {
      const x0 = seg * 250;
      let d = '';
      for (let j = 0; j <= 20; j++) {
        const x = x0 + (j / 20) * 250;
        const y = waveY(x / 1000, phase);
        d += `${j === 0 ? 'M' : 'L'}${x.toFixed(1)} ${y.toFixed(2)}`;
      }
      return d;
    }

    let last = performance.now();

    function frame(now: number) {
      const dt = Math.min(now - last, 50);
      last = now;

      dividers.forEach((d) => {
        if (!d.animating) return;
        d.phase += dt * 0.0011;
        d.paths.forEach((p, seg) => p.setAttribute('d', segPath(seg, d.phase)));
      });

      requestAnimationFrame(frame);
    }

    requestAnimationFrame(frame);
  }
</script>
