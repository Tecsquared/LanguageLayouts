---
import TemplateCard from './TemplateCard.astro';
import { services } from '../data/templates';
---

<section class="beyond-section" id="coaching">
  <div class="container">
    <h2 class="section-title reveal">Beyond the Templates</h2>
    <p class="section-subtitle reveal">Extra support to take your learning or teaching to the next level.</p>
  </div>

  <div class="carousel-wrapper reveal" data-carousel="services">
    <div class="carousel-3d-clip">
      <div class="carousel-3d">
        {services.map((s, i) => (
          <div class="carousel-3d-item" data-index={i}>
            <TemplateCard name={s.name} description={s.description} tags={s.tags} image={s.image} href="mailto:damienmherlihy@gmail.com" />
          </div>
        ))}
      </div>
    </div>

    <div class="carousel-dots">
      {services.map((_, i) => (
        <button
          class:list={['carousel-dot', { active: i === 0 }]}
          data-dot={i}
          aria-label={`Go to service ${i + 1}`}
        ></button>
      ))}
    </div>
  </div>
</section>

<style>
  .carousel-3d-clip {
    overflow: visible;
  }

  .beyond-section {
    overflow: hidden;
  }

  .carousel-wrapper {
    padding: 50px 0 20px;
  }

  .carousel-3d {
    position: relative;
    width: 100%;
    height: 700px;
    perspective: 1900px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .carousel-3d-item {
    position: absolute;
    width: 340px;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1),
                opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
                z-index 0s 0.3s;
    transform-style: preserve-3d;
  }

  /* Stitch-style pagination */
  .carousel-dots {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 9px;
    margin-top: 24px;
  }

  .carousel-dot {
    width: 16px;
    height: 5px;
    border-radius: 3px;
    border: none;
    background: var(--driftwood);
    opacity: 0.5;
    cursor: pointer;
    transition: background-color 0.3s, width 0.3s var(--ease-spring), opacity 0.3s, transform 0.2s var(--ease-spring);
    padding: 0;
    transform: rotate(-12deg);
  }

  .carousel-dot:hover {
    opacity: 0.9;
    transform: rotate(-12deg) scaleY(1.4);
  }

  .carousel-dot.active {
    background: var(--terra);
    opacity: 1;
    width: 30px;
  }

  @media (max-width: 768px) {
    .carousel-3d {
      height: 640px;
      perspective: 1200px;
    }

    .carousel-3d-item {
      width: 280px;
    }
  }

  @media (max-width: 480px) {
    .carousel-3d {
      height: 560px;
      perspective: 1000px;
    }

    .carousel-3d-item {
      width: 240px;
    }
  }
</style>
