---
interface Props {
  icon: string;
  title: string;
  subtitle: string;
  href: string;
}

const { icon, title, subtitle, href } = Astro.props;

const iconColors: Record<string, string> = {
  notion: 'var(--terra)',
  youtube: 'var(--mfo)',
  newsletter: 'var(--mfi)',
  contact: 'var(--fd)',
};

const iconColor = iconColors[icon] || 'var(--terra)';
---

<a href={href} class="connect-card" target="_blank" rel="noopener noreferrer">
  <span class="connect-icon" style={`--icon-color: ${iconColor};`} aria-hidden="true">
    {icon === 'notion' && (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <rect x="4" y="3" width="16" height="18" rx="2.5" />
        <path d="M8.5 8h7M8.5 12h7M8.5 16h4.5" />
      </svg>
    )}
    {icon === 'youtube' && (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2.5" y="5.5" width="19" height="13" rx="4" />
        <path d="M10.2 9.4l4.8 2.6-4.8 2.6z" fill="currentColor" stroke-linejoin="round" />
      </svg>
    )}
    {icon === 'newsletter' && (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 4 L3 11l7 2.5L12.5 20 21 4z" />
        <path d="M10 13.5l4.5-4.5" />
      </svg>
    )}
    {icon === 'contact' && (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 11.5a8.5 8.5 0 0 1-8.5 8.5c-1.5 0-3-.4-4.2-1.1L3 20l1.2-4.6A8.5 8.5 0 1 1 21 11.5Z" />
        <path d="M8.5 11.5h.01M12.5 11.5h.01M16.5 11.5h.01" stroke-width="2.4" />
      </svg>
    )}
  </span>

  <div class="connect-text">
    <span class="connect-title">{title}</span>
    <span class="connect-subtitle">{subtitle}</span>
  </div>

  <div class="connect-arrow" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M7 17L17 7M17 7H7M17 7v10" />
    </svg>
  </div>
</a>

<style>
  .connect-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 20px;
    border: 2px solid var(--ink);
    border-radius: var(--radius);
    background: var(--card);
    box-shadow: var(--shadow-sticker);
    height: 100%;
    box-sizing: border-box;
    transition: transform 0.35s var(--ease-spring), box-shadow 0.35s var(--ease-spring);
  }

  .connect-card:hover {
    transform: translate(-3px, -3px) rotate(-0.6deg);
    box-shadow: var(--shadow-sticker-lift);
  }

  .connect-card:active {
    transform: translate(2px, 2px);
    box-shadow: var(--shadow-sticker-press);
  }

  .connect-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    border-radius: 14px;
    flex-shrink: 0;
    color: var(--icon-color);
    background: color-mix(in srgb, var(--icon-color) 13%, var(--card));
    transition: transform 0.4s var(--ease-spring);
  }

  .connect-icon svg {
    width: 24px;
    height: 24px;
  }

  .connect-card:hover .connect-icon {
    transform: rotate(-8deg) scale(1.1);
  }

  .connect-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .connect-title {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: -0.01em;
  }

  .connect-subtitle {
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    color: var(--muted);
    text-transform: uppercase;
  }

  .connect-arrow {
    width: 20px;
    height: 20px;
    color: var(--driftwood);
    flex-shrink: 0;
    transition: transform 0.35s var(--ease-spring), color 0.25s var(--ease-out);
  }

  .connect-arrow svg {
    width: 100%;
    height: 100%;
  }

  .connect-card:hover .connect-arrow {
    transform: translate(3px, -3px);
    color: var(--terra);
  }
</style>
