---
import TemplateCard from './TemplateCard.astro';
import { templates } from '../data/templates';
---

<section class="templates-section" id="templates">
  <div class="container">
    <h2 class="templates-heading reveal">Language Layouts</h2>
    <p class="section-subtitle reveal">Research-backed Notion templates for learners and teachers.</p>
  </div>

  <div class="carousel-wrapper reveal" data-carousel="templates">
    <div class="carousel-3d-clip">
      <div class="carousel-3d">
        {templates.map((t, i) => (
          <div class="carousel-3d-item" data-index={i}>
            <TemplateCard name={t.name} description={t.description} tags={t.tags} image={t.image} href={t.link || "https://www.notion.com/@languagelayouts"} />
          </div>
        ))}
      </div>
    </div>

    <div class="carousel-dots">
      {templates.map((_, i) => (
        <button
          class:list={['carousel-dot', { active: i === 0 }]}
          data-dot={i}
          aria-label={`Go to template ${i + 1}`}
        ></button>
      ))}
    </div>

    <p class="carousel-hint hand-note" aria-hidden="true">give it a spin</p>
  </div>
</section>

<style>
  .carousel-3d-clip {
    overflow: visible;
  }

  .templates-section {
    overflow: hidden;
    background: var(--paper-deep);
    border-top: 2px dashed var(--line);
    border-bottom: 2px dashed var(--line);
  }

  .templates-heading {
    text-align: center;
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 14px;
  }

  .carousel-wrapper {
    padding: 90px 0 20px;
  }

  .carousel-3d {
    position: relative;
    width: 100%;
    height: 700px;
    perspective: 1900px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .carousel-3d-item {
    position: absolute;
    width: 340px;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1),
                opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
                z-index 0s 0.3s;
    transform-style: preserve-3d;
  }

  /* Stitch-style pagination */
  .carousel-dots {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 9px;
    margin-top: 24px;
  }

  .carousel-dot {
    width: 16px;
    height: 5px;
    border-radius: 3px;
    border: none;
    background: var(--driftwood);
    opacity: 0.5;
    cursor: pointer;
    transition: background-color 0.3s, width 0.3s var(--ease-spring), opacity 0.3s, transform 0.2s var(--ease-spring);
    padding: 0;
    transform: rotate(-12deg);
  }

  .carousel-dot:hover {
    opacity: 0.9;
    transform: rotate(-12deg) scaleY(1.4);
  }

  .carousel-dot.active {
    background: var(--terra);
    opacity: 1;
    width: 30px;
  }

  .carousel-hint {
    text-align: center;
    margin-top: 14px;
    font-size: 1.2rem;
    color: var(--muted);
    transform: rotate(-1.5deg);
  }

  @media (max-width: 768px) {
    .carousel-3d {
      height: 640px;
      perspective: 1200px;
    }

    .carousel-3d-item {
      width: 280px;
    }
  }

  @media (max-width: 480px) {
    .carousel-3d {
      height: 560px;
      perspective: 1000px;
    }

    .carousel-3d-item {
      width: 240px;
    }
  }
</style>

<script>
  // --- Carousel swish: short filtered-noise sweep, pitch follows direction ---
  let carouselAudio: AudioContext | null = null;
  let lastSwish = 0;

  function swish(dir: number) {
    const now = performance.now();
    if (now - lastSwish < 140) return;
    lastSwish = now;
    try {
      carouselAudio = carouselAudio || new AudioContext();
      if (carouselAudio.state === 'suspended') carouselAudio.resume().catch(() => {});
      const ctx = carouselAudio;
      const dur = 0.2;
      const buffer = ctx.createBuffer(1, ctx.sampleRate * dur, ctx.sampleRate);
      const data = buffer.getChannelData(0);
      for (let i = 0; i < data.length; i++) data[i] = Math.random() * 2 - 1;

      const noise = ctx.createBufferSource();
      noise.buffer = buffer;

      const filter = ctx.createBiquadFilter();
      filter.type = 'bandpass';
      filter.Q.value = 2;
      const from = dir > 0 ? 480 : 1500;
      const to = dir > 0 ? 1500 : 480;
      filter.frequency.setValueAtTime(from, ctx.currentTime);
      filter.frequency.exponentialRampToValueAtTime(to, ctx.currentTime + dur * 0.8);

      const gain = ctx.createGain();
      gain.gain.setValueAtTime(0.0001, ctx.currentTime);
      gain.gain.exponentialRampToValueAtTime(0.09, ctx.currentTime + 0.03);
      gain.gain.exponentialRampToValueAtTime(0.0001, ctx.currentTime + dur);

      noise.connect(filter);
      filter.connect(gain);
      gain.connect(ctx.destination);
      noise.start();
      noise.stop(ctx.currentTime + dur);
    } catch {
      // Audio unavailable — spin silently
    }
  }

  function initCarousel3D(wrapper: HTMLElement) {
    const container = wrapper.querySelector<HTMLElement>('.carousel-3d');
    const items = wrapper.querySelectorAll<HTMLElement>('.carousel-3d-item');
    const dots = wrapper.querySelectorAll<HTMLButtonElement>('.carousel-dot');

    let currentIndex = 0;
    const totalItems = items.length;

    // 3D carousel settings
    const radius = 380;         // translateZ distance
    // Dynamic angle: use 36° for larger sets, wider angles for smaller sets
    const angleStep = totalItems <= 3 ? 60 : totalItems <= 5 ? 45 : 36;

    function updatePositions() {
      items.forEach((item, i) => {
        // Calculate shortest distance considering wrap-around
        let offset = i - currentIndex;
        if (offset > totalItems / 2) offset -= totalItems;
        if (offset < -totalItems / 2) offset += totalItems;

        const angle = offset * angleStep;
        const absOffset = Math.abs(offset);

        // Progressive scaling and opacity based on distance from center
        let scale, opacity, zIndex;

        if (absOffset === 0) {
          scale = 1;
          opacity = 1;
          zIndex = 100;
        } else if (absOffset === 1) {
          scale = 0.67;
          opacity = 0.76;
          zIndex = 90;
        } else if (absOffset === 2) {
          scale = 0.60;
          opacity = 0.66;
          zIndex = 65;
        } else if (absOffset === 3) {
          scale = 0.52;
          opacity = 0.54;
          zIndex = 35;
        } else {
          scale = 0.45;
          opacity = 0;
          zIndex = 0;
        }

        item.style.transform = `rotateY(${angle}deg) translateZ(${radius}px) scale(${scale})`;
        item.style.opacity = String(opacity);
        item.style.zIndex = String(zIndex);

        // Visible cards stay clickable (side cards rotate to front on click);
        // fully faded cards ignore the pointer
        item.style.pointerEvents = opacity > 0 ? 'auto' : 'none';
      });

      dots.forEach((dot, i) => {
        dot.classList.toggle('active', i === currentIndex);
      });
    }

    function goToSlide(index: number) {
      // Wrap around
      const next = ((index % totalItems) + totalItems) % totalItems;
      if (next === currentIndex) return;

      // Shortest wrapped distance gives the spin direction for the swish
      let offset = next - currentIndex;
      if (offset > totalItems / 2) offset -= totalItems;
      if (offset < -totalItems / 2) offset += totalItems;
      swish(Math.sign(offset));

      currentIndex = next;
      updatePositions();
    }

    // One delegated listener (capture phase) handles arrows and side cards,
    // so a click can never fall through to the card link by mistake
    wrapper.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;

      const arrow = target.closest('.card-prev-inner, .card-next-inner');
      if (arrow) {
        e.preventDefault();
        e.stopPropagation();
        goToSlide(currentIndex + (arrow.classList.contains('card-next-inner') ? 1 : -1));
        return;
      }

      const item = target.closest('.carousel-3d-item') as HTMLElement | null;
      if (item) {
        const idx = parseInt(item.dataset.index || '0');
        if (idx !== currentIndex) {
          // Side card clicked: bring it to the front instead of following its link
          e.preventDefault();
          e.stopPropagation();
          goToSlide(idx);
        }
      }
    }, true);

    // Dot handlers
    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const index = parseInt(dot.dataset.dot || '0');
        goToSlide(index);
      });
    });

    // Touch/swipe support
    let touchStartX = 0;
    container?.addEventListener('touchstart', (e) => {
      touchStartX = e.touches[0].clientX;
    }, { passive: true });

    container?.addEventListener('touchend', (e) => {
      const touchEndX = e.changedTouches[0].clientX;
      const diff = touchStartX - touchEndX;
      if (Math.abs(diff) > 50) {
        goToSlide(currentIndex + (diff > 0 ? 1 : -1));
      }
    }, { passive: true });

    // Initialize
    updatePositions();

    // Recalculate on resize
    window.addEventListener('resize', () => updatePositions());
  }

  // Init all carousels on the page
  document.querySelectorAll<HTMLElement>('[data-carousel]').forEach(initCarousel3D);
</script>
