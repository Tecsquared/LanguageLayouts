---
const line1 = 'Language';
const line2 = 'Layouts';

// Drifting glyphs from scripts around the world — pure background charm
const glyphs = [
  { ch: 'あ', top: '12%', left: '4%',  size: '3.4rem', color: 'var(--mfi)', dur: '11s', delay: '0s' },
  { ch: 'Ñ',  top: '64%', left: '2%',  size: '2.6rem', color: 'var(--lfl)', dur: '13s', delay: '1.2s' },
  { ch: 'ก',  top: '24%', left: '46%', size: '2.8rem', color: 'var(--fd)',  dur: '12s', delay: '0.6s', hideMobile: true },
  { ch: '字', top: '78%', left: '38%', size: '3rem',   color: 'var(--mfo)', dur: '14s', delay: '2s', hideMobile: true },
  { ch: 'é',  top: '8%',  left: '70%', size: '2.4rem', color: 'var(--terra)', dur: '10s', delay: '0.3s', hideMobile: true },
  { ch: '한', top: '16%', left: '90%', size: '3rem',   color: 'var(--mfo)', dur: '12.5s', delay: '1.6s' },
  { ch: 'ß',  top: '58%', left: '94%', size: '2.5rem', color: 'var(--mfi)', dur: '11.5s', delay: '0.9s' },
  { ch: 'ह',  top: '86%', left: '74%', size: '2.7rem', color: 'var(--fd)',  dur: '13.5s', delay: '2.4s', hideMobile: true },
];

const greetings = ['Hello!', '¡Hola!', 'สวัสดี!', 'Bonjour!', 'こんにちは!', 'Hallo!', 'Ciao!', '안녕!', 'Olá!', 'Cześć!'];
---

<section class="hero">
  <div class="hero-glyphs" aria-hidden="true">
    {glyphs.map((g) => (
      <span
        class:list={['glyph', { 'glyph-hide-mobile': g.hideMobile }]}
        style={`top: ${g.top}; left: ${g.left}; font-size: ${g.size}; color: ${g.color}; animation-duration: ${g.dur}; animation-delay: ${g.delay};`}
      >{g.ch}</span>
    ))}
  </div>

  <div class="container hero-grid">
    <div class="hero-text">
      <div class="greeting-chip">
        <svg class="greeting-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12a8 8 0 1 0-3.1 6.3L21 19l-0.8-2.6A7.9 7.9 0 0 0 21 12Z" />
          <path d="M8.5 11h.01M12 11h.01M15.5 11h.01" stroke-width="2.4" />
        </svg>
        <span class="greeting-mask">
          <span class="greeting-word" id="greeting-word">{greetings[0]}</span>
        </span>
      </div>

      <h1 class="hero-title" aria-label="Language Layouts">
        <span class="title-line" aria-hidden="true">
          {line1.split('').map((ch, i) => (
            <span class="ch" style={`--ci: ${i}; --hc: var(--${['mfi', 'mfo', 'lfl', 'fd', 'terra'][i % 5]});`}>
              <span class="chi">{ch}</span>
            </span>
          ))}
        </span>
        <span class="title-line line-two" aria-hidden="true">
          {line2.split('').map((ch, i) => (
            <span class="ch" style={`--ci: ${i + line1.length}; --hc: var(--${['lfl', 'fd', 'terra', 'mfi', 'mfo'][i % 5]});`}>
              <span class="chi">{ch}</span>
            </span>
          ))}
          <svg class="title-squiggle" viewBox="0 0 320 24" fill="none" aria-hidden="true">
            <path
              pathLength="1"
              d="M6 14 C40 4, 70 22, 105 13 C140 4, 170 21, 205 12 C240 4, 270 19, 314 10"
              stroke="var(--terra)"
              stroke-width="5"
              stroke-linecap="round"
              fill="none"
            />
          </svg>
        </span>
      </h1>

      <p class="hero-subtitle">
        Notion templates for students who want true mastery
        and teachers who deliver results.
      </p>

      <div class="hero-actions">
        <a href="#templates" class="btn btn-primary" id="hero-cta">Get Templates</a>
        <a href="#framework" class="hero-link">
          Learn the Framework
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </a>
      </div>

      <div class="hero-annotation" aria-hidden="true">
        <svg class="annotation-arrow" viewBox="0 0 60 40" fill="none">
          <path pathLength="1" class="arrow-path" d="M54 36 C40 32, 22 28, 12 10" stroke="var(--terra)" stroke-width="2" stroke-linecap="round" fill="none" />
          <path pathLength="1" class="arrow-path" d="M8 18 L12 8 L21 11" stroke="var(--terra)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none" />
        </svg>
        <span class="hand-note">psst — some are free!</span>
      </div>
    </div>

    <div class="hero-media">
      <div class="video-frame">
        <span class="tape tape-left"></span>
        <span class="tape tape-right"></span>
        <video autoplay loop muted playsinline>
          <source src="/images/hero-animation.mp4" type="video/mp4" />
        </video>
      </div>
      <svg class="spark spark-1" viewBox="0 0 24 24" fill="var(--lfl)" aria-hidden="true">
        <path d="M12 0l2.6 9.4L24 12l-9.4 2.6L12 24l-2.6-9.4L0 12l9.4-2.6L12 0z" />
      </svg>
      <svg class="spark spark-2" viewBox="0 0 24 24" fill="var(--terra)" aria-hidden="true">
        <path d="M12 0l2.6 9.4L24 12l-9.4 2.6L12 24l-2.6-9.4L0 12l9.4-2.6L12 0z" />
      </svg>
      <svg class="spark spark-3" viewBox="0 0 24 24" fill="var(--fd)" aria-hidden="true">
        <path d="M12 0l2.6 9.4L24 12l-9.4 2.6L12 24l-2.6-9.4L0 12l9.4-2.6L12 0z" />
      </svg>
    </div>
  </div>

  <!-- Multilingual hello marquee — the site says hi on the way in -->
  <div class="hello-marquee" aria-hidden="true">
    <div class="hello-track">
      {[...greetings, ...greetings, ...greetings].map((word, i) => (
        <span class="hello-word" style={`--hw: ${i % 4};`}>{word.replace('!', '')}</span>
      ))}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 150px 0 0;
    overflow: hidden;
  }

  /* --- Drifting background glyphs --- */
  .hero-glyphs {
    position: absolute;
    inset: 0;
    pointer-events: none;
    user-select: none;
  }

  .glyph {
    position: absolute;
    font-family: var(--font-heading);
    font-weight: 800;
    opacity: 0.14;
    animation: float-drift ease-in-out infinite;
  }

  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    align-items: center;
    gap: 48px;
    padding-bottom: 90px;
  }

  /* --- Greeting chip --- */
  .greeting-chip {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    border: 2px solid var(--ink);
    border-radius: 999px;
    background: var(--card);
    box-shadow: 3px 3px 0 var(--ink);
    padding: 6px 18px 6px 14px;
    margin-bottom: 28px;
    animation: pop-in 0.7s var(--ease-spring) 0.15s both;
  }

  .greeting-icon {
    width: 21px;
    height: 21px;
    color: var(--terra);
    flex-shrink: 0;
  }

  .greeting-mask {
    display: block;
    overflow: hidden;
    height: 1.9rem;
    min-width: 7.5ch;
  }

  .greeting-word {
    display: block;
    font-family: var(--font-hand);
    font-size: 1.45rem;
    font-weight: 700;
    line-height: 1.9rem;
    color: var(--terra);
    white-space: nowrap;
    transition: transform 0.3s var(--ease-out), opacity 0.3s var(--ease-out);
  }

  .greeting-word.word-out {
    transform: translateY(-110%);
    opacity: 0;
  }

  .greeting-word.word-prep {
    transition: none;
    transform: translateY(110%);
    opacity: 0;
  }

  /* --- Bouncy title --- */
  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(3.2rem, 8.5vw, 5.6rem);
    font-weight: 900;
    line-height: 0.98;
    letter-spacing: -0.02em;
    margin-bottom: 26px;
  }

  .title-line {
    display: block;
    white-space: nowrap;
  }

  .line-two {
    position: relative;
    width: fit-content;
  }

  .ch {
    display: inline-block;
    animation: ch-in 0.65s var(--ease-spring) both;
    animation-delay: calc(0.25s + var(--ci) * 0.045s);
  }

  @keyframes ch-in {
    from {
      opacity: 0;
      transform: translateY(0.55em) rotate(6deg);
    }
    to {
      opacity: 1;
      transform: translateY(0) rotate(0deg);
    }
  }

  .chi {
    display: inline-block;
    transition: transform 0.3s var(--ease-spring), color 0.3s var(--ease-out);
  }

  .ch:hover .chi {
    transform: translateY(-0.12em) rotate(-5deg) scale(1.08);
    color: var(--hc);
  }

  .title-squiggle {
    position: absolute;
    left: 0;
    right: -4%;
    bottom: -0.28em;
    width: 104%;
    height: 0.32em;
    overflow: visible;
  }

  .title-squiggle path {
    stroke-dasharray: 1 1;
    stroke-dashoffset: 1;
    animation: draw-squiggle 0.8s var(--ease-out) 1.15s forwards;
  }

  @keyframes draw-squiggle {
    to { stroke-dashoffset: 0; }
  }

  .hero-subtitle {
    font-size: 1.12rem;
    color: var(--ink-soft);
    line-height: 1.7;
    max-width: 42ch;
    animation: ch-in 0.7s var(--ease-out) 0.9s both;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 26px;
    margin-top: 34px;
    animation: ch-in 0.7s var(--ease-out) 1.05s both;
  }

  .btn-primary {
    font-size: 1rem;
    padding: 14px 30px;
  }

  .hero-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--ink-soft);
    border-bottom: 2px dashed var(--driftwood);
    padding-bottom: 3px;
    transition: color 0.25s var(--ease-out), border-color 0.25s var(--ease-out);
  }

  .hero-link svg {
    width: 16px;
    height: 16px;
    transition: transform 0.3s var(--ease-spring);
  }

  .hero-link:hover {
    color: var(--terra);
    border-color: var(--terra);
  }

  .hero-link:hover svg {
    transform: translateX(4px);
  }

  /* --- Hand-written annotation --- */
  .hero-annotation {
    display: flex;
    align-items: flex-end;
    gap: 6px;
    margin-top: 18px;
    margin-left: 8px;
    transform: rotate(-2deg);
    animation: ch-in 0.7s var(--ease-out) 1.7s both;
  }

  .annotation-arrow {
    width: 44px;
    height: 30px;
  }

  .arrow-path {
    stroke-dasharray: 1 1;
    stroke-dashoffset: 1;
    animation: draw-squiggle 0.7s var(--ease-out) 2s forwards;
  }

  .hero-annotation .hand-note {
    font-size: 1.25rem;
  }

  /* --- Framed video with washi tape --- */
  .hero-media {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .video-frame {
    position: relative;
    background: var(--card);
    border: 2px solid var(--ink);
    border-radius: var(--radius-lg);
    padding: 14px;
    box-shadow: var(--shadow-soft);
    transform: rotate(2.5deg);
    transition: transform 0.5s var(--ease-spring), box-shadow 0.5s var(--ease-out);
    animation: pop-in 0.9s var(--ease-spring) 0.5s both;
  }

  .video-frame:hover {
    transform: rotate(0.5deg) translateY(-4px);
    box-shadow: var(--shadow-lift);
  }

  .video-frame video {
    max-width: 100%;
    height: auto;
    border-radius: calc(var(--radius-lg) - 12px);
    background: #FFFFFF;
  }

  .tape-left {
    top: -13px;
    left: 28px;
    transform: rotate(-8deg);
  }

  .tape-right {
    top: -13px;
    right: 28px;
    transform: rotate(7deg);
  }

  .spark {
    position: absolute;
    width: 22px;
    height: 22px;
    animation: twinkle 3.2s ease-in-out infinite;
  }

  .spark-1 { top: -6px; right: 10%; }
  .spark-2 { bottom: 4%; left: 4%; width: 16px; height: 16px; animation-delay: 1.1s; }
  .spark-3 { top: 38%; right: -10px; width: 14px; height: 14px; animation-delay: 2.2s; }

  /* --- Hello marquee --- */
  .hello-marquee {
    overflow: hidden;
    padding: 18px 0;
    border-top: 2px dashed var(--line);
    border-bottom: 2px dashed var(--line);
    background: var(--paper-deep);
    -webkit-mask-image: linear-gradient(90deg, transparent, black 6%, black 94%, transparent);
    mask-image: linear-gradient(90deg, transparent, black 6%, black 94%, transparent);
  }

  .hello-track {
    display: flex;
    gap: 56px;
    width: max-content;
    animation: marquee-scroll 30s linear infinite;
  }

  .hello-marquee:hover .hello-track {
    animation-play-state: paused;
  }

  .hello-word {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .hello-word[style*='--hw: 0'] { color: var(--mfi); }
  .hello-word[style*='--hw: 1'] { color: var(--mfo); }
  .hello-word[style*='--hw: 2'] { color: var(--lfl); }
  .hello-word[style*='--hw: 3'] { color: var(--fd); }

  /* --- Confetti pieces (spawned by JS) --- */
  :global(.confetti-bit) {
    position: fixed;
    width: 9px;
    height: 13px;
    border-radius: 2px;
    pointer-events: none;
    z-index: var(--z-progress);
  }

  @media (max-width: 880px) {
    .hero {
      padding-top: 120px;
    }

    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 36px;
      padding-bottom: 64px;
    }

    .hero-text {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .hero-subtitle {
      margin: 0 auto;
    }

    .hero-actions {
      justify-content: center;
      flex-wrap: wrap;
    }

    .hero-annotation {
      margin-left: 0;
    }

    .hero-media {
      order: -1;
    }

    .line-two {
      margin: 0 auto;
    }

    .glyph-hide-mobile {
      display: none;
    }

    .glyph {
      opacity: 0.1;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding-top: 104px;
    }

    .hero-title {
      font-size: 2.9rem;
    }

    .hero-subtitle {
      font-size: 1rem;
    }

    .hero-actions {
      gap: 16px;
      margin-top: 26px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ch,
    .greeting-chip,
    .hero-subtitle,
    .hero-actions,
    .hero-annotation,
    .video-frame {
      animation: none;
      opacity: 1;
      transform: none;
    }

    .title-squiggle path,
    .arrow-path {
      animation: none;
      stroke-dashoffset: 0;
    }

    .hello-track {
      animation: none;
    }
  }
</style>

<script>
  // --- Greeting rotator ---
  const GREETINGS = ['Hello!', '¡Hola!', 'สวัสดี!', 'Bonjour!', 'こんにちは!', 'Hallo!', 'Ciao!', '안녕!', 'Olá!', 'Cześć!'];
  const wordEl = document.getElementById('greeting-word');
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (wordEl && !reducedMotion) {
    let gi = 0;
    setInterval(() => {
      wordEl.classList.add('word-out');
      setTimeout(() => {
        gi = (gi + 1) % GREETINGS.length;
        wordEl.textContent = GREETINGS[gi];
        wordEl.classList.remove('word-out');
        wordEl.classList.add('word-prep');
        void wordEl.offsetHeight; // reflow so the prep position applies without transition
        wordEl.classList.remove('word-prep');
      }, 320);
    }, 2400);
  }

  // --- Confetti on the main CTA ---
  const CONFETTI_COLORS = ['#5A7F6E', '#7A6BA0', '#C49A3C', '#6B8DB5', '#B85C38'];
  const cta = document.getElementById('hero-cta');

  if (cta && !reducedMotion) {
    cta.addEventListener('click', () => {
      const rect = cta.getBoundingClientRect();
      const cx = rect.left + rect.width / 2;
      const cy = rect.top + rect.height / 2;

      for (let i = 0; i < 26; i++) {
        const bit = document.createElement('span');
        bit.className = 'confetti-bit';
        bit.style.left = `${cx}px`;
        bit.style.top = `${cy}px`;
        bit.style.background = CONFETTI_COLORS[i % CONFETTI_COLORS.length];
        if (i % 3 === 0) bit.style.borderRadius = '50%';
        document.body.appendChild(bit);

        const angle = (Math.PI * 2 * i) / 26 + (Math.random() - 0.5) * 0.6;
        const power = 70 + Math.random() * 110;
        const dx = Math.cos(angle) * power;
        const dy = Math.sin(angle) * power * 0.7 - 60;
        const fall = 120 + Math.random() * 100;
        const spin = (Math.random() - 0.5) * 540;
        const dur = 750 + Math.random() * 450;

        const anim = bit.animate(
          [
            { transform: 'translate(0, 0) rotate(0deg)', opacity: 1 },
            { transform: `translate(${dx}px, ${dy}px) rotate(${spin * 0.6}deg)`, opacity: 1, offset: 0.45 },
            { transform: `translate(${dx * 1.25}px, ${dy + fall}px) rotate(${spin}deg)`, opacity: 0 },
          ],
          { duration: dur, easing: 'cubic-bezier(0.22, 1, 0.36, 1)' }
        );
        anim.onfinish = () => bit.remove();
      }
    });
  }
</script>
