---
---

<section class="sounds-familiar">
  <div class="container">
    <h2 class="section-title reveal">Sounds Familiar?</h2>
    <div class="cards reveal-stagger">
      <div class="problem-card card-tilt-left reveal" style="--reveal-rot: -4deg; --reveal-rot-end: -1.6deg;">
        <span class="tape card-tape"></span>
        <div class="card-illustration">
          <img src="/images/learner-illustration.png" alt="Learner floating in space illustration" loading="lazy" />
        </div>
        <h3 class="card-audience">For Learners</h3>
        <p class="card-question">
          Is your language learning leading to meaningful
          progress or just points and streaks?
        </p>
        <span class="card-scribble hand-note" aria-hidden="true">another 400-day streak…</span>
      </div>

      <div class="problem-card card-tilt-right reveal" style="--reveal-rot: 4deg; --reveal-rot-end: 1.6deg;">
        <span class="tape card-tape"></span>
        <div class="card-illustration">
          <img src="/images/teacher-illustration.png" alt="Teacher problem solving illustration" loading="lazy" />
        </div>
        <h3 class="card-audience">For Teachers</h3>
        <p class="card-question">
          Are your lessons building complete language users
          or just covering what's easiest to plan?
        </p>
        <span class="card-scribble hand-note" aria-hidden="true">unit 7, again, sigh</span>
      </div>
    </div>
  </div>
</section>

<style>
  .sounds-familiar {
    padding-top: 80px;
  }

  .cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    max-width: 880px;
    margin: 0 auto;
  }

  .problem-card {
    position: relative;
    text-align: center;
    padding: 48px 28px 36px;
    background: var(--card);
    border: 2px solid var(--ink);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-soft);
    transition: transform 0.5s var(--ease-spring), box-shadow 0.5s var(--ease-out);
  }

  .card-tilt-left.visible:hover,
  .card-tilt-right.visible:hover {
    transform: rotate(0deg) translateY(-6px);
    box-shadow: var(--shadow-lift);
  }

  .card-tape {
    top: -14px;
    left: 50%;
    margin-left: -46px;
    transform: rotate(-3deg);
  }

  .card-illustration {
    width: 210px;
    height: 210px;
    margin: 0 auto 20px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-illustration img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.5s var(--ease-spring);
  }

  .problem-card:hover .card-illustration img {
    transform: scale(1.05) rotate(-1.5deg);
  }

  .card-audience {
    font-family: var(--font-heading);
    font-size: 1.7rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    margin-bottom: 12px;
  }

  .card-question {
    color: var(--muted);
    font-size: 0.98rem;
    line-height: 1.7;
    max-width: 32ch;
    margin: 0 auto;
  }

  .card-scribble {
    position: absolute;
    bottom: -16px;
    right: 18px;
    font-size: 1.15rem;
    color: var(--driftwood);
    transform: rotate(-3deg);
    opacity: 0;
    transition: opacity 0.4s var(--ease-out), transform 0.4s var(--ease-spring);
  }

  .problem-card:hover .card-scribble {
    opacity: 1;
    transform: rotate(-5deg) translateY(-3px);
    color: var(--terra);
  }

  @media (max-width: 768px) {
    .cards {
      grid-template-columns: 1fr;
      gap: 44px;
      max-width: 420px;
    }
  }

  @media (hover: none) {
    .card-scribble {
      opacity: 1;
      color: var(--terra);
    }
  }
</style>
