---
import ConnectCard from './ConnectCard.astro';
import { connectLinks } from '../data/templates';
---

<section class="stay-connected" id="connect">
  <div class="container stay-connected-grid">
    <div class="stay-connected-text reveal">
      <svg class="connected-squiggle" viewBox="0 0 80 14" fill="none" aria-hidden="true">
        <path d="M2 8 C12 2, 20 12, 30 7 C40 2, 48 12, 58 7 C66 3, 72 8, 78 6" stroke="var(--lfl)" stroke-width="3" stroke-linecap="round" fill="none" />
      </svg>
      <h2 class="connected-heading">Stay<br />Connected</h2>
      <p class="connected-description">
        Join the community of learners and
        educators building better systems for
        language mastery.
      </p>
      <p class="connected-note hand-note" aria-hidden="true">say hi in any language</p>
    </div>

    <div class="connect-cards reveal-stagger">
      {connectLinks.map((link) => (
        <div class="reveal">
          <ConnectCard icon={link.icon} title={link.title} subtitle={link.subtitle} href={link.href} />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stay-connected-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 64px;
    align-items: start;
  }

  .connected-squiggle {
    width: 72px;
    height: 14px;
    margin-bottom: 18px;
  }

  .connected-heading {
    font-family: var(--font-heading);
    font-size: clamp(2.4rem, 4.5vw, 3rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
  }

  .connected-description {
    color: var(--muted);
    font-size: 0.98rem;
    line-height: 1.7;
    max-width: 34ch;
  }

  .connected-note {
    margin-top: 14px;
    font-size: 1.3rem;
    transform: rotate(-2deg);
    display: inline-block;
  }

  .connect-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-auto-rows: 1fr;
    gap: 18px;
  }

  /* Tiny alternating tilt so the grid feels hand-placed */
  .connect-cards > .reveal:nth-child(odd) {
    transform-origin: center;
    rotate: -0.5deg;
  }

  .connect-cards > .reveal:nth-child(even) {
    rotate: 0.5deg;
  }

  @media (max-width: 768px) {
    .stay-connected-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .connect-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
